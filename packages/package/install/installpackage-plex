#!/usr/bin/env bash
#
# [AetherFlow :: Install plexmediaserver package]
#

set -euo pipefail

source /opt/AetherFlow/packages/common.sh

PACKAGE_NAME="plex"
LOCAL_SETUP="/opt/AetherFlow/setup/"
APACHE_SITE="/etc/apache2/sites-enabled/plex.conf"
FQDN_CONF="/etc/apache2/conf-available/fqdn.conf"
PLEX_LIST="/etc/apt/sources.list.d/plexmediaserver.list"
PLEX_KEYRING="/etc/apt/keyrings/plex.gpg"
SYSTEMD_UNIT="/lib/systemd/system/plexmediaserver.service"
SYSTEMD_TEMPLATE="${LOCAL_SETUP}templates/sysd/plexmediaserver.template"

ROLLBACK_RESTORE=()
ROLLBACK_REMOVE=()
PACKAGE_WAS_PRESENT=false

track_file() {
    local path="$1"
    if [[ -e "$path" ]]; then
        cp -a "$path" "${path}.bak-af"
        ROLLBACK_RESTORE+=("$path")
    else
        ROLLBACK_REMOVE+=("$path")
    fi
}

rollback_changes() {
    local exit_code="$1"
    set +e
    if [[ "$exit_code" -eq 0 ]]; then
        for path in "${ROLLBACK_RESTORE[@]}"; do
            rm -f "${path}.bak-af"
        done
        return 0
    fi

    print_error "Plex installation failed. Rolling back changes."
    remove_lock "$PACKAGE_NAME"

    for path in "${ROLLBACK_RESTORE[@]}"; do
        if [[ -f "${path}.bak-af" ]]; then
            mv -f "${path}.bak-af" "$path"
        fi
    done

    for path in "${ROLLBACK_REMOVE[@]}"; do
        rm -f "$path"
    done

    if [[ "$PACKAGE_WAS_PRESENT" == "false" ]] && dpkg -s plexmediaserver >/dev/null 2>&1; then
        apt-get remove -y plexmediaserver >>"$LOGFILE" 2>&1 || true
    fi

    systemctl daemon-reload >/dev/null 2>&1 || true
    systemctl restart apache2 >/dev/null 2>&1 || true
    return "$exit_code"
}

trap 'rollback_changes "$?"' EXIT

require_root
print_info "Starting Plex installation..."

if dpkg -s plexmediaserver >/dev/null 2>&1; then
    PACKAGE_WAS_PRESENT=true
    print_info "Plex already installed. Re-applying configuration."
fi

HOSTNAME_SHORT="$(hostname -s)"
PUBLIC_IP="$(ip route get 8.8.8.8 | awk 'NR==1 {print $NF}')"

mkdir -p /etc/apt/keyrings
apt-get update >>"$LOGFILE" 2>&1
apt-get install -y curl gnupg apt-transport-https >>"$LOGFILE" 2>&1

track_file "$FQDN_CONF"
printf 'ServerName %s\n' "$HOSTNAME_SHORT" >"$FQDN_CONF"
a2enconf fqdn >>"$LOGFILE" 2>&1

track_file "$APACHE_SITE"
cp "${LOCAL_SETUP}templates/plex.conf.template" "$APACHE_SITE"
chown www-data: "$APACHE_SITE"
sed -i "s/PUBLICIP/${PUBLIC_IP}/g" "$APACHE_SITE"
a2enmod proxy proxy_http >>"$LOGFILE" 2>&1

track_file "$PLEX_LIST"
printf 'deb [signed-by=%s] https://downloads.plex.tv/repo/deb public main\n' "$PLEX_KEYRING" >"$PLEX_LIST"

if [[ -e "$PLEX_KEYRING" ]]; then
    track_file "$PLEX_KEYRING"
else
    ROLLBACK_REMOVE+=("$PLEX_KEYRING")
fi
curl -fsSL https://downloads.plex.tv/plex-keys/PlexSign.key | gpg --dearmor --yes -o "$PLEX_KEYRING"

apt-get update >>"$LOGFILE" 2>&1
if [[ "$PACKAGE_WAS_PRESENT" == "false" ]]; then
    apt-get install -y -o Dpkg::Options::="--force-confold" plexmediaserver >>"$LOGFILE" 2>&1
fi

mkdir -p /var/lib/plexmediaserver
if id -u plex >/dev/null 2>&1; then
    chown -R plex:plex /var/lib/plexmediaserver
fi

if [[ -f "$SYSTEMD_TEMPLATE" ]]; then
    track_file "$SYSTEMD_UNIT"
    cp "$SYSTEMD_TEMPLATE" "$SYSTEMD_UNIT"
fi

systemctl daemon-reload >>"$LOGFILE" 2>&1
systemctl enable plexmediaserver >>"$LOGFILE" 2>&1
systemctl restart plexmediaserver >>"$LOGFILE" 2>&1
systemctl reload apache2 >>"$LOGFILE" 2>&1

write_lock "$PACKAGE_NAME"
print_info "Plex installation completed successfully."

exit 0
