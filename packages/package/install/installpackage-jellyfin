#!/usr/bin/env bash
#
# [AetherFlow :: Install Jellyfin]
#

set -euo pipefail

source /opt/AetherFlow/packages/common.sh

PACKAGE_NAME="jellyfin"
JELLYFIN_SOURCES="/etc/apt/sources.list.d/jellyfin.sources"
JELLYFIN_KEYRING="/etc/apt/keyrings/jellyfin.gpg"
APACHE_SITE="/etc/apache2/sites-enabled/jellyfin.conf"

ROLLBACK_RESTORE=()
ROLLBACK_REMOVE=()
PACKAGE_WAS_PRESENT=false

track_file() {
    local path="$1"
    if [[ -e "$path" ]]; then
        cp -a "$path" "${path}.bak-af"
        ROLLBACK_RESTORE+=("$path")
    else
        ROLLBACK_REMOVE+=("$path")
    fi
}

rollback_changes() {
    local exit_code="$1"
    set +e
    if [[ "$exit_code" -eq 0 ]]; then
        for path in "${ROLLBACK_RESTORE[@]}"; do
            rm -f "${path}.bak-af"
        done
        return 0
    fi

    print_error "Jellyfin installation failed. Rolling back changes."
    remove_lock "$PACKAGE_NAME"

    for path in "${ROLLBACK_RESTORE[@]}"; do
        if [[ -f "${path}.bak-af" ]]; then
            mv -f "${path}.bak-af" "$path"
        fi
    done

    for path in "${ROLLBACK_REMOVE[@]}"; do
        rm -f "$path"
    done

    if [[ "$PACKAGE_WAS_PRESENT" == "false" ]] && dpkg -s jellyfin >/dev/null 2>&1; then
        apt-get remove -y jellyfin >>"$LOGFILE" 2>&1 || true
    fi

    systemctl daemon-reload >/dev/null 2>&1 || true
    systemctl restart apache2 >/dev/null 2>&1 || true
    return "$exit_code"
}

trap 'rollback_changes "$?"' EXIT

require_root
print_info "Starting Jellyfin installation..."

if dpkg -s jellyfin >/dev/null 2>&1; then
    PACKAGE_WAS_PRESENT=true
    print_info "Jellyfin already installed. Re-applying configuration."
fi

mkdir -p /etc/apt/keyrings
apt-get update >>"$LOGFILE" 2>&1
apt-get install -y curl gnupg ca-certificates >>"$LOGFILE" 2>&1

if [[ -e "$JELLYFIN_KEYRING" ]]; then
    track_file "$JELLYFIN_KEYRING"
else
    ROLLBACK_REMOVE+=("$JELLYFIN_KEYRING")
fi
curl -fsSL https://repo.jellyfin.org/jellyfin_team.gpg.key | gpg --dearmor --yes -o "$JELLYFIN_KEYRING"

ARCH="$(dpkg --print-architecture)"
CODENAME="$(. /etc/os-release && printf '%s' "${VERSION_CODENAME:-bookworm}")"

track_file "$JELLYFIN_SOURCES"
cat >"$JELLYFIN_SOURCES" <<EOF
Types: deb
URIs: https://repo.jellyfin.org/debian
Suites: ${CODENAME}
Components: main
Architectures: ${ARCH}
Signed-By: ${JELLYFIN_KEYRING}
EOF

apt-get update >>"$LOGFILE" 2>&1
if [[ "$PACKAGE_WAS_PRESENT" == "false" ]]; then
    apt-get install -y jellyfin >>"$LOGFILE" 2>&1
fi

systemctl daemon-reload >>"$LOGFILE" 2>&1
systemctl enable jellyfin.service >>"$LOGFILE" 2>&1
systemctl restart jellyfin.service >>"$LOGFILE" 2>&1

track_file "$APACHE_SITE"
cat >"$APACHE_SITE" <<'EOF'
<Location /jellyfin>
    ProxyPreserveHost On
    RequestHeader set X-Forwarded-Proto "https"
    ProxyPass http://127.0.0.1:8096/jellyfin retry=0 timeout=120
    ProxyPassReverse http://127.0.0.1:8096/jellyfin
</Location>

<Location /jellyfin/socket>
    ProxyPass ws://127.0.0.1:8096/jellyfin/socket
    ProxyPassReverse ws://127.0.0.1:8096/jellyfin/socket
</Location>
EOF

chown www-data:www-data "$APACHE_SITE"
a2enmod proxy proxy_http proxy_wstunnel headers >>"$LOGFILE" 2>&1
systemctl reload apache2 >>"$LOGFILE" 2>&1

write_lock "$PACKAGE_NAME"
print_info "Jellyfin installation completed successfully."

exit 0
