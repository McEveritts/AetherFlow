source /opt/AetherFlow/packages/common.sh

if [ ! -f /opt/AetherFlow/config/interface.txt ]; then
    echo "No interface config found at /opt/AetherFlow/config/interface.txt"
    exit 1
fi

ADAPT=$(cat /opt/AetherFlow/config/interface.txt)
echo "Network interface set to: ${ADAPT}"
