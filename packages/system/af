#################################################################################

function _intro() {
  whiptail --title "AetherFlow Package Manager" --msgbox "Welcome to the AetherFlow Package Manger! Using this script you can choose to install and remove the packages contained within our AetherFlow package repository. Use the arrow keys to navigate, spacebar to toggle the currently selected item and enter to continue." 15 50
}

function _function() {
  function=$(whiptail --title "QBPM" --menu "Choose an option:" --ok-button "Continue" --nocancel 12 50 3 \
               Install "packages" \
               Remove "packages" \
               Exit "" 3>&1 1>&2 2>&3)

    if [[ $function == Install ]]; then
      _install
    elif [[ $function == Remove ]]; then
      _remove
    elif [[ $function == Exit ]]; then
      exit 0
    fi
}

function _install() {
  installa=()
  mapfile -t locks < <(find /usr/local/bin/AetherFlow/package/install -type f -printf "%f\n" | cut -d "-" -f 2 | sort -d)
  for i in "${locks[@]}"; do
    app=${i}
    if [[ $i == autodl ]]; then app=autodlirssi; fi
    if [[ ! -f /install/.$app.lock ]]; then
      installa+=("$i" '""')
    fi
  done
  local results_file
  results_file="$(mktemp)"
	whiptail --title "Install Software" --checklist --noitem --separate-output "Make some choices:" 15 26 7 "${installa[@]}" 2>"${results_file}"
  readarray packages < "${results_file}"
  rm -f "${results_file}"
  for i in "${packages[@]}"; do
    i="${i//\"/}"
    echo -e "Installing $i "
    bash "/usr/local/bin/AetherFlow/package/install/installpackage-$i"
  done
  _function
}

function _remove() {
removea=()
mapfile -t locks < <(find /usr/local/bin/AetherFlow/package/remove -type f -printf "%f\n" | cut -d "-" -f 2 | sort -d)
for i in "${locks[@]}"; do
  app=${i}
  if [[ $i == autodl ]]; then app=autodlirssi; fi
  if [[ -f /install/.$app.lock ]]; then
    removea+=("$i" '""')
  fi
done
local results_file
results_file="$(mktemp)"
whiptail --title "Remove Software" --noitem --checklist --separate-output "Make some choices:" 15 26 7 "${removea[@]}" 2>"${results_file}"
readarray packages < "${results_file}"
rm -f "${results_file}"
for i in "${packages[@]}"; do
  i="${i//\"/}"
  echo -e "Removing $i "
  bash "/usr/local/bin/AetherFlow/package/remove/removepackage-$i"
done
_function
}

function _cli() {
  arg=("$@")
  packages=("${arg[@]:1}")
  mapfile -t repo < <(find /usr/local/bin/AetherFlow/package/install -type f -printf "%f\n" | cut -d "-" -f 2)
  for i in "${packages[@]}"; do
    app=${i}
    if [[ $i == autodl ]]; then app=autodlirssi; fi
    if [[ -f /install/.${app}.lock ]]; then
      echo -e "Package $i already installed"
    else
      if printf '%s\n' "${repo[@]}" | grep -Fxq "$i"; then
        echo -e "Installing $i "
        bash "/usr/local/bin/AetherFlow/package/install/installpackage-$i"
      else
        echo -e "Package $i not found"
      fi
    fi
  done
}

function _clr() {
  arg=("$@")
  packages=("${arg[@]:1}")
  for i in "${packages[@]}"; do
    app=${i}
    if [[ $i == autodl ]]; then app=autodlirssi; fi
    if [[ -f /install/.$app.lock ]]; then
      echo -e "Removing $i "
      bash "/usr/local/bin/AetherFlow/package/remove/removepackage-$i"
    else
      echo -e "Package $i not installed"
    fi
  done
}

function _updateqb() {
  echo -e "Updating AetherFlow local repository"
  if [[ ! -f /install/.developer.lock ]]; then
    if [[ -d /opt/AetherFlow ]]; then
      cd /opt/AetherFlow || { echo "Critical: /opt/AetherFlow not found!"; exit 1; }
      git stash --include-untracked -m "af-update-$(date +%s)" 2>/dev/null || true
      git checkout master 2>/dev/null
      if ! git pull --ff-only 2>/dev/null; then
        echo "[WARN] Fast-forward failed, attempting rebase..."
        if ! git pull --rebase 2>/dev/null; then
          echo "[ERROR] Rebase failed (conflicts). Aborting update."
          git rebase --abort 2>/dev/null
          return 1
        fi
      fi
    else
      git clone --recursive https://github.com/McEveritts/AetherFlow /opt/AetherFlow
    fi
  else
    if [[ -d /opt/AetherFlow ]]; then
      cd /opt/AetherFlow || { echo "Critical: /opt/AetherFlow not found!"; exit 1; }
      git stash --include-untracked -m "af-update-dev-$(date +%s)" 2>/dev/null || true
      if git rev-parse --verify origin/development >/dev/null 2>&1; then
        git checkout development 2>/dev/null
        if ! git pull --ff-only 2>/dev/null; then
          echo "[WARN] Fast-forward failed, attempting rebase..."
          if ! git pull --rebase 2>/dev/null; then
            echo "[ERROR] Rebase failed (conflicts). Aborting update."
            git rebase --abort 2>/dev/null
            return 1
          fi
        fi
      else
        echo "[WARN] development branch not found on remote, falling back to master"
        git checkout master 2>/dev/null
        if ! git pull --ff-only 2>/dev/null; then
          git pull --rebase 2>/dev/null || { git rebase --abort 2>/dev/null; return 1; }
        fi
      fi
    else
      git clone --recursive --branch "development" https://github.com/McEveritts/AetherFlow /opt/AetherFlow 2>/dev/null || \
        git clone --recursive https://github.com/McEveritts/AetherFlow /opt/AetherFlow
    fi
  fi
}

function _help() {
  sgformat="${bold}%-15s${normal}"
  spacing=$(echo $'\t' | pr -Te15)

  echo -e "Usage: $(basename "$0") [ install | remove ] ${bold}pkg1 pkg2 [...]${normal}\n"
  echo -e "       $(basename "$0") [ list | update | upgrade ]\n"
  echo -e "       $(basename "$0")\n"
  echo -e "Note: Only install and remove functions accept package arguments. List and update must be run without modifiers\n" | fmt --goal=66 --tagged-paragraph
  echo -e "\n"
  printf "${sgformat}" "install"
  echo -e "The install function requires at least one package name as an argument but will accept multiples\n" | fmt --goal=50 | sed -e "2,\$s/^/$spacing/"
  echo -e "               Example: af install quassel syncthing znc\n" | fmt --goal=50 | sed -e "2,\$s/^/$spacing/"
  printf "${sgformat}" "remove"
  echo -e "The remove function requires at least one package name as an argument but will accept multiples\n" | fmt --goal=50 | sed -e "2,\$s/^/$spacing/"
  echo -e "               Example: af remove quassel syncthing znc\n" | fmt --goal=50 | sed -e "2,\$s/^/$spacing/"
  printf "${sgformat}" "update"
  echo -e "The update command will update your local AetherFlow repository to the latest version\n" | fmt --goal=50 | sed -e "2,\$s/^/$spacing/"
  printf "${sgformat}" "upgrade"
  echo -e "The upgrade command will update your local AetherFlow installation to the latest version\n" | fmt --goal=50 | sed -e "2,\$s/^/$spacing/"
  printf "${sgformat}" "list"
  echo -e "The list command will list packages available to be managed by af\n" | fmt --goal=50 | sed -e "2,\$s/^/$spacing/"
}

function _list() {
  mapfile -t repo < <(find /usr/local/bin/AetherFlow/package/install -type f -printf "%f\n" | cut -d "-" -f 2 | sort -d)
  for i in "${repo[@]}"; do
    app=$i
    sgformat="${bold}%-15s${normal}"
    spacing=$(echo $'\t' | pr -Te15)
    # Check installation status
    if [[ -f /install/.${app}.lock ]]; then
      status="[installed]"
    else
      status="[available]"
    fi
    printf "${sgformat}" "$i"
    echo -e "${status}\n" | fmt --goal=50 | sed -e "2,\$s/^/$spacing/"
  done
}

normal=$(tput sgr0)
yellow=$(tput setaf 3)
bold=$(tput bold)
if [[ -z "${1:-}" ]]; then
  _intro
  _function
  exit 0
fi
if [[ "$1" == "-h" ]]; then
  _help "$0"
  exit 0
fi
if [[ ! "${1}" =~ ("install"|"list"|"remove"|"update"|"upgrade") ]]; then
  echo "Error: $1 invalid command"
  exit 0
fi
if [[ $1 == update ]]; then
  _updateqb
  exit 0
fi
if [[ $1 == upgrade ]]; then
    # Update AetherFlow local repository before upgrade
  _updateqb
  echo "Upgrading AetherFlow ... This may take a moment"
  if [[ ! -f /install/.developer.lock ]]; then
    if [[ -d /opt/AetherFlow ]]; then
      bash /opt/AetherFlow/packages/system/updateAetherFlow
    else
      git clone --recursive https://github.com/McEveritts/AetherFlow /opt/AetherFlow
      bash /opt/AetherFlow/packages/system/updateAetherFlow
    fi
  else
    if [[ -d /opt/AetherFlow ]]; then
      bash /opt/AetherFlow/packages/system/updateAetherFlow
    else
      git clone --recursive --branch "development" https://github.com/McEveritts/AetherFlow /opt/AetherFlow 2>/dev/null || \
        git clone --recursive https://github.com/McEveritts/AetherFlow /opt/AetherFlow
      bash /opt/AetherFlow/packages/system/updateAetherFlow
    fi
  fi
  #printf "" > "$LOGFILE"
  exit 0
fi
if [[ $1 == list ]]; then
  _list
  exit 0
fi
if [[ -n "${1:-}" ]] && [[ -z "${2:-}" ]]; then
  echo "Error: You must choose some packages"
  exit 0
fi
if [[ $1 == install ]]; then
  _cli "$@"
  exit 0
fi
if [[ $1 == remove ]]; then
  _clr "$@"
  exit 0
fi
