source /opt/AetherFlow/packages/common.sh 2>/dev/null || true

JSON_OUTPUT=0
USERNAME=""
SIZE=""

print_usage() {
  echo "Usage: setdisk [--username USER] [--size 500GB] [--json]"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --username)
        USERNAME="$2"
        shift 2
        ;;
      --size)
        SIZE="$2"
        shift 2
        ;;
      --json)
        JSON_OUTPUT=1
        shift
        ;;
      --help|-h)
        print_usage
        exit 0
        ;;
      *)
        echo "Unknown argument: $1" >&2
        print_usage >&2
        exit 1
        ;;
    esac
  done
}

prompt_if_needed() {
  if [[ -z "${USERNAME}" ]]; then
    echo "================================================================================="
    echo "Disk Space MUST be in GB/TB - Do not attempt to add decimals in space settings,"
    echo "Example - Good: 711GB OR 2TB, Example - Bad: 711.5GB OR 2.5TB"
    echo "================================================================================="
    echo
    echo -n "Username: "
    read -r USERNAME
  fi

  if [[ -z "${SIZE}" ]]; then
    echo "Quota size for user: (EX: 500GB): "
    read -r SIZE
  fi
}

apply_quota() {
  local quantity disk_blocks quota_bytes
  case "${SIZE^^}" in
    *TB)
      quantity="${SIZE^^}"
      quantity="${quantity%TB}"
      [[ "${quantity}" =~ ^[0-9]+$ ]] || return 1
      disk_blocks=$((quantity * 1024 * 1024 * 1024))
      quota_bytes=$((disk_blocks * 1024))
      ;;
    *GB)
      quantity="${SIZE^^}"
      quantity="${quantity%GB}"
      [[ "${quantity}" =~ ^[0-9]+$ ]] || return 1
      disk_blocks=$((quantity * 1024 * 1024))
      quota_bytes=$((disk_blocks * 1024))
      ;;
    *MB)
      quantity="${SIZE^^}"
      quantity="${quantity%MB}"
      [[ "${quantity}" =~ ^[0-9]+$ ]] || return 1
      disk_blocks=$((quantity * 1024))
      quota_bytes=$((disk_blocks * 1024))
      ;;
    *)
      return 1
      ;;
  esac

  setquota -u "${USERNAME}" "${disk_blocks}" "${disk_blocks}" 0 0 -a

  if [[ ${JSON_OUTPUT} -eq 1 ]]; then
    printf '{"username":"%s","quota":"%s","quota_bytes":%s,"status":"applied"}\n' "${USERNAME}" "${SIZE^^}" "${quota_bytes}"
  else
    echo "Quota updated for ${USERNAME}: ${SIZE^^}"
  fi
}

parse_args "$@"
prompt_if_needed

if ! apply_quota; then
  if [[ ${JSON_OUTPUT} -eq 1 ]]; then
    printf '{"error":"Invalid quota size. Use integer MB, GB, or TB values.","status":"failed"}\n'
  else
    echo "================================================================================="
    echo "Disk Space MUST be in GB/TB - Do not attempt to add decimals in space settings,"
    echo "Example - Good: 711GB OR 2TB, Example - Bad: 711.5GB OR 2.5TB"
    echo "Exiting script, type bash $0 and try again"
    echo "================================================================================="
  fi
  exit 1
fi
