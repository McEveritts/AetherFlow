#!/bin/bash
#
# [AetherFlow :: Set French Language/Locale]
#
# NOTE: Legacy rutorrent PHP localization removed.
# AetherFlow now uses Next.js frontend with browser-native i18n.
# This script sets the system locale only.
#
# Author: McEveritts | URL: https://AetherFlow.io
# Licensed under GNU General Public License v3.0 GPL-3

source /opt/AetherFlow/packages/common.sh
locale='fr_FR.UTF-8'

echo "[AetherFlow] Setting system locale to ${locale}"
export LANG=${locale}
export LC_ALL=${locale}

if command -v update-locale &>/dev/null; then
    update-locale LANG=${locale} LC_ALL=${locale} 2>/dev/null || true
fi

echo "[AetherFlow] Locale set to ${locale}. Dashboard language is managed in Settings."
